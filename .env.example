# Environment variables for Nutri-Lens
# ─────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Run `bash setup.sh` to get step-by-step help.

# ── Google OAuth (required) ───────────────────────────────────────────
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create a "Web application" OAuth 2.0 Client ID
# 3. Add http://localhost:5173 as an Authorised JavaScript Origin
# 4. Paste the Client ID below

VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE

# ── Groq API (required for AI meal suggestions on the Results page) ───
# 1. Go to https://console.groq.com/keys
# 2. Sign up / log in (free tier available)
# 3. Create an API key and paste it below
# Model used: llama3-70b-8192 (fast, accurate, free on Groq)

VITE_GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE

# ── Spoonacular API (optional — enhances ingredient search) ───────────
# 1. Go to https://spoonacular.com/food-api/console
# 2. Sign up (free tier: 150 requests/day, no credit card)
# 3. Copy your API key and paste it below
# Without this key, ingredient search uses local data only.

VITE_SPOONACULAR_API_KEY=YOUR_SPOONACULAR_API_KEY_HERE
